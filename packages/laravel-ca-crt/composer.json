{
    "name": "groupesti/laravel-ca-crt",
    "description": "X.509 certificate management for Laravel CA",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "groupesti/laravel-ca": "^1.0",
        "groupesti/laravel-ca-key": "^1.0",
        "groupesti/laravel-ca-csr": "^1.0",
        "phpseclib/phpseclib": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CA\\Crt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CA\\Crt\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CA\\Crt\\CrtServiceProvider"
            ],
            "aliases": {
                "CaCrt": "CA\\Crt\\Facades\\CaCrt"
            }
        }
    }
}
