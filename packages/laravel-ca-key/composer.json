{
    "name": "groupesti/laravel-ca-key",
    "description": "Key management for Laravel CA - RSA, ECDSA, Ed25519",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "groupesti/laravel-ca": "^1.0",
        "phpseclib/phpseclib": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CA\\Key\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CA\\Key\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CA\\Key\\KeyServiceProvider"
            ],
            "aliases": {
                "CaKey": "CA\\Key\\Facades\\CaKey"
            }
        }
    }
}
