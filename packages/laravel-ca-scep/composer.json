{
    "name": "groupesti/laravel-ca-scep",
    "description": "SCEP (Simple Certificate Enrollment Protocol) server for Laravel CA",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "groupesti/laravel-ca": "^0.1",
        "groupesti/laravel-ca-crt": "^0.1",
        "groupesti/laravel-ca-csr": "^0.1",
        "groupesti/laravel-ca-key": "^0.1",
        "phpseclib/phpseclib": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CA\\Scep\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CA\\Scep\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CA\\Scep\\ScepServiceProvider"
            ],
            "aliases": {
                "CaScep": "CA\\Scep\\Facades\\CaScep"
            }
        }
    }
}
